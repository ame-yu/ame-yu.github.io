.site-nav-toggle {
  display: none;
  left: 10px;
  position: absolute;

  +mobile() {
    display: block;
  }

  button {
    background: transparent;
    border: 0;
    margin-top: 2px;
    padding: 9px 10px;
  }
}

.site-nav {
  display: block;
  background #fff8!important
  +mobile() {
    background #fff3!important
    a{
      color #333
    }
    clear: both;
    display: none;
    margin: 0 -10px;
    padding: 0 10px;
  }

  &.site-nav-on {
    display: block;
  }
  .menu{
    margin: 0; 
  }
}
